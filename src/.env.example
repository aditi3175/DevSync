# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/devsync?retryWrites=true&w=majority

# Redis 
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_TOKEN_SECRET=replace_with_a_strong_random_secret
JWT_REFRESH_TOKEN_SECRET=replace_with_another_strong_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Email (dev)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="DevSync <noreply@devsync.local>"

# Payments
STRIPE_SECRET_KEY=sk_test_xxx
